node_modules
build/
dist/
.refs/
# Non-final plan/review working copies. Final records are archived under ref/ and tracked.
.DS_Store
*.log
!ref/plans/**/spike-reports/**/*.log
# Spike report logs are measured command-output traces. Keep them tracked with the
# related spike report so historical evidence stays reviewable.
.vite
*.tsbuildinfo
.deep-code-review/
# Legacy directory, now migrated to user-scoped ~/.claude/state/deep-code-review/<cwd-slug>/.
# Keep this defensive ignore in case a tool regression or manual run recreates it.
.deep-review-cache/
# deep-review sandbox cache. Each invocation creates a subdirectory plus manifest.
# Worktree cache directories must stay out of git and fast-forward merges.
.prompt-asset-improver/local/
# Local prompt-asset-improver inventory, backups, and custom points.
ref/architecture/*.png
ref/architecture/*.svg
ref/flows/*.png
ref/flows/*.svg
# PlantUML .puml files are the source of truth. Rendered PNG/SVG output stays untracked.
# Reviewers may generate these files while running syntax checks or rendering previews.
.claude/worktrees/
.claude/scheduled_tasks*
.claude/plans/
.claude/settings.local*
# Claude Code runtime state: worktree temp dirs, cron task state and locks, local
# plan workspaces, and per-user permission allow lists. Do not commit per-user or
# per-machine state. Completed plans are archived to ref/plans/<plan-id>.md.

