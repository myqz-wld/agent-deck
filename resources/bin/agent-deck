#!/usr/bin/env bash
# Agent Deck CLI wrapper（macOS）
#
# 用法：
#   agent-deck new [--cwd <path>] [--prompt "..."] [--agent claude-code]
#                  [--model <name>] [--thinking <level>]
#                  [--permission-mode default|acceptEdits|plan|bypassPermissions]
#                  [--system-prompt "..."] [--resume <sessionId>] [--no-focus]
#
# 行为：
#   - 把 --cwd 的相对路径在 shell 端转成绝对路径，避免转发给主实例后被
#     主实例自己的 process.cwd()（一般是 / 或 .app 安装目录）重新解析。
#   - 如果是 `new` 但没传 --cwd，自动用当前 PWD 作为 --cwd。
#   - 把归一化后的 argv 编成单个 payload，避开 Electron 对 --flag/value 的重排。
#   - `--version` / `version` 打印安装包构建 commit，并在当前目录是
#     agent-deck 源码 checkout 时对比当前 HEAD / origin/main。
#   - 应用未运行 → 由 macOS 自动拉起首启实例，CLI 参数走首启分支。
#   - 应用已运行 → second-instance 事件转发参数到主实例处理。
#
# 环境变量：
#   AGENT_DECK_APP    覆盖默认 .app 路径（默认 /Applications/Agent Deck.app）
#
# 安装到 PATH：
#   ln -sf "$(pwd)/resources/bin/agent-deck" /usr/local/bin/agent-deck
# 或者：
#   ln -sf "/Applications/Agent Deck.app/Contents/Resources/bin/agent-deck" /usr/local/bin/agent-deck

set -e

APP_PATH="${AGENT_DECK_APP:-/Applications/Agent Deck.app}"
EXEC_PATH="$APP_PATH/Contents/MacOS/Agent Deck"
BUILD_INFO_PATH="$APP_PATH/Contents/Resources/build-info.json"

json_string() {
  local key="$1"
  local file="$2"
  sed -nE 's/^[[:space:]]*"'"$key"'"[[:space:]]*:[[:space:]]*"([^"]*)".*/\1/p' "$file" | head -1
}

json_bool() {
  local key="$1"
  local file="$2"
  sed -nE 's/^[[:space:]]*"'"$key"'"[[:space:]]*:[[:space:]]*(true|false).*/\1/p' "$file" | head -1
}

find_source_repo() {
  local dir="$PWD"
  while [[ "$dir" != "/" ]]; do
    if [[ -f "$dir/package.json" ]] && grep -q '"name"[[:space:]]*:[[:space:]]*"agent-deck"' "$dir/package.json"; then
      printf '%s\n' "$dir"
      return 0
    fi
    dir="$(dirname "$dir")"
  done
  return 1
}

print_build_status() {
  if [[ ! -f "$BUILD_INFO_PATH" ]]; then
    echo "Agent Deck: 未找到安装包 build-info.json"
    echo "  查找路径: $BUILD_INFO_PATH"
    if [[ -x "$EXEC_PATH" ]]; then
      echo "  提示: 这是旧安装包或未通过当前打包脚本构建，无法按 commit 判断是否最新。"
      return 2
    fi
    echo "  提示: 未找到可执行文件: $EXEC_PATH"
    return 2
  fi

  local name version commit short_commit branch dirty built_at
  name="$(json_string name "$BUILD_INFO_PATH")"
  version="$(json_string version "$BUILD_INFO_PATH")"
  commit="$(json_string commit "$BUILD_INFO_PATH")"
  short_commit="$(json_string shortCommit "$BUILD_INFO_PATH")"
  branch="$(json_string branch "$BUILD_INFO_PATH")"
  dirty="$(json_bool dirty "$BUILD_INFO_PATH")"
  built_at="$(json_string builtAt "$BUILD_INFO_PATH")"

  echo "Agent Deck ${version:-unknown}"
  echo "  installed commit: ${commit:-unknown} (${short_commit:-unknown})"
  echo "  installed branch: ${branch:-unknown}"
  echo "  installed dirty: ${dirty:-unknown}"
  echo "  built at: ${built_at:-unknown}"

  local repo
  if repo="$(find_source_repo 2>/dev/null)"; then
    local head short_head origin_main short_origin source_dirty
    head="$(git -C "$repo" rev-parse HEAD 2>/dev/null || true)"
    short_head="$(git -C "$repo" rev-parse --short=12 HEAD 2>/dev/null || true)"
    origin_main="$(git -C "$repo" rev-parse --verify --quiet origin/main 2>/dev/null || true)"
    short_origin="$(git -C "$repo" rev-parse --short=12 --verify --quiet origin/main 2>/dev/null || true)"
    source_dirty="$(git -C "$repo" status --porcelain 2>/dev/null || true)"
    echo "  source checkout: $repo"
    echo "  source HEAD: ${head:-unknown} (${short_head:-unknown})"
    if [[ -n "$source_dirty" ]]; then
      echo "  source dirty: true"
    else
      echo "  source dirty: false"
    fi
    if [[ -n "$origin_main" ]]; then
      echo "  origin/main: $origin_main ($short_origin)"
    fi
    if [[ -n "$head" && "$commit" == "$head" ]]; then
      if [[ -n "$source_dirty" ]]; then
        echo "  status: installed build matches this checkout commit, but the source checkout has uncommitted changes"
      else
        echo "  status: installed build matches this checkout commit"
      fi
      return 0
    fi
    if [[ -n "$origin_main" && "$commit" == "$origin_main" ]]; then
      echo "  status: installed build matches origin/main but differs from this checkout"
      return 1
    fi
    echo "  status: installed build differs from this checkout"
    return 1
  fi

  echo "  status: no agent-deck source checkout found under current directory"
  return 0
}

case "${1:-}" in
  --version|version)
    print_build_status || true
    exit 0
    ;;
  --check-installed|check-installed)
    status=0
    print_build_status || status=$?
    exit "$status"
    ;;
esac

if [[ ! -x "$EXEC_PATH" ]]; then
  echo "agent-deck: 找不到 Agent Deck.app（默认查 /Applications，AGENT_DECK_APP 可覆盖）" >&2
  echo "  当前查找路径：$APP_PATH" >&2
  exit 1
fi

# 简化形式：用户可省略 'new' 子命令
#   agent-deck                 → new --cwd "$PWD"（最简）
#   agent-deck --prompt "..."  → new --prompt "..."（首参就是 flag 时也自动补 new）
# 显式带子命令的（agent-deck new ...）保持原样。
if (( $# == 0 )); then
  set -- new
elif [[ "$1" == --* ]]; then
  set -- new "$@"
fi

# 把相对路径转成绝对（保留尾随空格安全）
abs() {
  local p="$1"
  case "$p" in
    /*) printf '%s\n' "$p" ;;
    *)
      if [[ -d "$p" ]]; then
        (cd "$p" && pwd)
      else
        # 路径不存在也照传绝对形式，让主进程报清晰的 ENOENT
        printf '%s/%s\n' "$PWD" "$p"
      fi
      ;;
  esac
}

NEW_ARGS=()
HAS_CWD=0
HAS_NEW=0
HAS_PERMISSION_MODE=0

i=1
while (( i <= $# )); do
  cur="${!i}"
  case "$cur" in
    new)
      HAS_NEW=1
      NEW_ARGS+=("$cur")
      ;;
    --permission-mode)
      HAS_PERMISSION_MODE=1
      NEW_ARGS+=("$cur")
      ((i++))
      NEW_ARGS+=("${!i}")
      ;;
    --permission-mode=*)
      HAS_PERMISSION_MODE=1
      NEW_ARGS+=("$cur")
      ;;
    --cwd)
      HAS_CWD=1
      NEW_ARGS+=("$cur")
      ((i++))
      val="${!i}"
      if [[ -z "$val" ]]; then
        echo "agent-deck: --cwd 缺少值" >&2
        exit 2
      fi
      NEW_ARGS+=("$(abs "$val")")
      ;;
    --cwd=*)
      HAS_CWD=1
      NEW_ARGS+=("--cwd" "$(abs "${cur#--cwd=}")")
      ;;
    *)
      NEW_ARGS+=("$cur")
      ;;
  esac
  ((i++))
done

# new 子命令但用户没传 --cwd → 自动补当前 PWD（按用户终端所在的目录）
if (( HAS_NEW == 1 && HAS_CWD == 0 )); then
  NEW_ARGS+=("--cwd" "$PWD")
fi

# new 子命令但用户没传 --permission-mode → 默认 bypassPermissions
if (( HAS_NEW == 1 && HAS_PERMISSION_MODE == 0 )); then
  NEW_ARGS+=("--permission-mode" "bypassPermissions")
fi

if (( HAS_NEW == 1 )); then
  # Electron/macOS 会把普通 `--flag value` argv 重排为 switches-before-positionals，导致
  # second-instance 入口拿不到 key/value 邻接关系。传一个非 switch payload，让主进程解码后
  # 再按原 parser 处理。
  PAYLOAD="$(printf '%s\0' "${NEW_ARGS[@]}" | base64 | tr -d '\n')"
  exec "$EXEC_PATH" new "agent-deck-argv-b64:$PAYLOAD"
fi

exec "$EXEC_PATH" "${NEW_ARGS[@]}"
