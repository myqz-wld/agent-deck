' plan: mcp-handoff-worktree-redesign-20260609
' description: hand_off_session session baton sequence
' last_updated: 2026-06-09
@startuml hand-off-session-flow

title hand_off_session — session baton sequence

actor Caller as C
participant "hand_off_session handler" as H
participant "spawn_session handler" as SP
participant "resource transfer" as RT
database "session / team / task tables" as DB
participant "session manager" as SM
participant "successor SDK" as SDK

C -> H: hand_off_session(prompt, cwd?, adapter?, sandbox?)
H -> DB: load caller session row
alt caller missing or cwd invalid
  H --> C: error
else valid caller
  H -> SP: spawn(prompt, cwd, handOff={mode:'session'})
  SP -> SDK: create successor SDK session
  SP -> DB: insert successor session + first user message event
  SP --> H: spawn result { sessionId, cwd, ... }

  H -> RT: transfer(callerSid, successorSid)
  RT -> DB: copy worktree marker when present
  RT -> DB: swap lead memberships / add teammate memberships
  RT -> DB: reassign caller tasks to successor, preserve teamId
  RT --> H: resourceTransfer

  H -> SM: close caller session
  SM -> DB: lifecycle=closed + clear caller marker + leave teams
  SM --> H: callerClosed
  H --> C: ok(spawn fields + initialPrompt + callerClosed + resourceTransfer)
end

note right of H
  No plan mode exists in this tool.
  Put plan path, /tmp context file path,
  and next action directly in prompt.
end note

@enduml
