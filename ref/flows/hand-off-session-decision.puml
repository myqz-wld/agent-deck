@startuml hand-off-session-decision

title hand_off_session — session baton decision tree

start
:Caller invokes hand_off_session(prompt, cwd?, adapter?);

if (caller is real in-process session?) then (no)
  :reject;
  stop
endif

:load caller session row;
if (cwd override or caller cwd exists?) then (no)
  :reject before spawn;
  stop
endif

:spawn successor with handOff metadata;
if (spawn failed or no successor sessionId?) then (yes)
  :return spawn error;
  stop
endif

:transfer worktree marker if caller has one;
:transfer active team memberships;
if (caller is team lead?) then (yes)
  :swapLead caller -> successor;
else (teammate)
  :add successor as teammate;
endif

:reassign caller-owned tasks to successor with teamId preserved;
:close caller session;
:return ok with resourceTransfer and callerClosed;

stop

@enduml
