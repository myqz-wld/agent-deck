' description: hand_off_session 双模式分流 + adopt + task + cleanup 决策树
' last_updated: 2026-05-29
@startuml hand-off-session-decision

title hand_off_session — 决策树 (3 段: 分流 / spawn+adopt / cleanup)

start

:Caller invoke hand_off_session(args);

if (入口拦截器: 白名单允许?) then (no)
  :reject (deny external);
  end
endif

:反查 caller cwd (DB);

' ─── 段 1: 双模式分流 ───
partition "段 1: 双模式分流 (plan-driven vs generic)" {
  if (plan_id 传?) then (yes — plan-driven)
    :按 fallback 链找 plan 文件;
    if (plan 文件存在 + status=in_progress + worktree_path 非空?) then (no)
      :reject;
      end
    endif
    :构造 cold start prompt "按 <plan-abs-path> 接力";
    :cwd 默认 = mainRepo (cwd resilience);
  else (no — generic)
    :不调 plan resolve;
    :cold start prompt = args.prompt 或默认;
    :cwd 默认 = caller cwd;
  endif
  :cwd 兜底链 + 失效自动回退;
}

' ─── 段 2: spawn + adopt + task ───
partition "段 2: spawn 新 SDK session + adopt + task 三态" {
  :spawn 新 session (handOffMode=true → 跳防御 + 不写 spawn-link);
  if (spawn 失败?) then (yes)
    :reject;
    end
  endif

  if (adopt_teammates=true?) then (yes)
    :≥1 lead 硬约束: caller 必须至少在 1 个 team 是 lead;
    :转交 lead 角色 (per team loop, firstTeam 优先);
    note right
      firstTeam swap 失败 → 回滚 newSid + reject
      非 firstTeam 失败 → 软失败继续
    end note
  endif

  if (archive_caller=false?) then (yes)
    :task 过继 skip (caller 仍 own);
  else (no)
    :按 team_task_policy 三态过继 task\n(clear-team / preserve-team / skip);
    note right
      reassign throw 仅 warn 不阻塞
    end note
  endif
}

' ─── 段 3: cleanup ───
partition "段 3: baton cleanup (与 archive_plan 共享 helper)" {
  if (adopt_teammates=true?) then (yes)
    :skip phase 1 (teammate 已转给 newSid);
  else (no)
    :phase 1: 关 caller 同 team 全部 teammate\n(excludeSessionIds={newSid} 防新 session 被一并关);
  endif

  if (archive_caller=false?) then (yes)
    :skip phase 2 (caller 仍 active);
  else (no)
    :phase 2: 归档 caller session;
    note right
      archive throw → archived='failed' warn-only
    end note
  endif
}

:return ok(mode, sessionId, archived, adopted?, taskReassignment, ...);

stop

@enduml
