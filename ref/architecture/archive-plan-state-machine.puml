' plan: mcp-handoff-worktree-redesign-20260609
' description: Retired archive_plan state machine boundary.
' last_updated: 2026-06-09
' ARCHIVED: archive_plan no longer drives public MCP state transitions.
@startuml archive-plan-state-machine

title archive_plan — retired public state machine

state "Public MCP registry" as Registry {
  [*] --> "16 active tools"
  "16 active tools" --> "archive_plan absent"
}

state "Project closeout" as Closeout {
  [*] --> "project or skill decides records"
  "project or skill decides records" --> "git/project files updated"
  "git/project files updated" --> [*]
}

state "Worktree cleanup" as Cleanup {
  [*] --> "worktree exists"
  "worktree exists" --> "remove rejected" : dirty and discardChanges != true
  "worktree exists" --> "worktree removed" : exit_worktree
  "worktree removed" --> "branch kept"
  "branch kept" --> "branch deleted" : deleteBranch=true and git allows deletion
}

note right of Registry
  Retired names remain only as guard/type compatibility keys.
  They are not exposed to SDK agents by buildAgentDeckTools.
end note

note right of Cleanup
  Keeping the branch by default preserves committed work after the worktree directory is removed.
end note

@enduml
