' description: hand_off_session state machine
' last_updated: 2026-06-09
@startuml hand-off-session-state-machine

title hand_off_session — state machine

state "Caller session" as Caller {
  [*] --> active
  active --> transferring : spawn successor
  transferring --> closed : resources transferred\nsessionManager.close
}

state "Successor session" as Successor {
  [*] --> spawned : spawn_session
  spawned --> owner : marker / teams / tasks assigned
  owner --> [*]
}

state "Worktree marker" as Marker {
  [*] --> heldByCaller
  heldByCaller --> heldBySuccessor : marker copied
  heldBySuccessor --> [*]
}

state "Team memberships" as Team {
  [*] --> callerMember
  callerMember --> successorLead : caller was lead\nswapLead
  callerMember --> successorTeammate : caller was teammate\naddMember
}

state "Tasks" as Tasks {
  [*] --> ownerCaller
  ownerCaller --> ownerSuccessor : reassignOwner\npreserve teamId
}

note bottom
  The caller closes even when individual transfer results report failure.
  The ok return exposes resourceTransfer for follow-up handling.
end note

@enduml
